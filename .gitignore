# Hugo默认忽略文件
/public/
/resources/_gen/
/assets/jsconfig.json
hugo_stats.json

# 临时文件
*.tmp
*.temp
.DS_Store
Thumbs.db

# 编辑器文件
.vscode/
.idea/
*.swp
*.swo

# 环境文件
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 日志文件
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 依赖目录
node_modules/
bower_components/

# 构建产物
dist/
build/
out/

# 系统文件
*.sys
*.dll
*.exe

# Hugo主题（如果是git submodule）
/themes/

# 本地开发文件
.hugo_build.lock

# 测试文件
_test/
coverage.txt
cover.out

# 配置文件
config_local.toml
config_*.toml